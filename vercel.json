{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://stegagen-auth-server.onrender.com/api/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://stegagen-api.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
