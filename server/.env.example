# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Email Configuration (Gmail example)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here
# From must match your authenticated mailbox/domain for best deliverability
EMAIL_FROM="StegaGen Secure <your_email@gmail.com>"
EMAIL_REPLY_TO=your_email@gmail.com
# Optional: used in Message-ID header when using a custom domain
# EMAIL_DOMAIN=yourdomain.com

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate an App Password (Google Account > Security)
# 3. Use that app password as EMAIL_PASSWORD
# 4. Set EMAIL_FROM to the same Gmail address

# Frontend URL(s) — comma-separated; first URL is used in verification email links
FRONTEND_URL=http://localhost:3000,http://localhost:5173

# Verification settings
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRY=600000
VERIFICATION_CODE_SECRET=change-this-to-a-long-random-string
# Local-only fallback without Supabase table:
# USE_IN_MEMORY_VERIFICATION=true

# App name used in email subject/body
APP_NAME=StegaGen Secure
