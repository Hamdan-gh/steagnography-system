# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Python Processing Engine
# Local dev:
VITE_PROCESSING_ENGINE_URL=http://localhost:5000
# Production (Vercel): leave unset — frontend uses same-origin /api via vercel.json proxy.
# Only set this if you want to bypass the proxy and call Render directly:
# VITE_PROCESSING_ENGINE_URL=https://stegagen-api.onrender.com

# Application Settings
VITE_APP_NAME=StegaGen Secure
VITE_APP_VERSION=1.0.0

# Encryption
VITE_ENCRYPTION_KEY=your_encryption_key_here
