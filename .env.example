# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Auth API (Vercel serverless — set these in Vercel dashboard, NOT with VITE_ prefix)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM="StegaGen Secure <your_email@gmail.com>"
EMAIL_REPLY_TO=your_email@gmail.com
FRONTEND_URL=https://steagnography-system.vercel.app
VERIFICATION_CODE_SECRET=long-random-secret-string
APP_NAME=StegaGen Secure

# Recommended for Vercel production (Gmail SMTP often fails on serverless)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM="StegaGen Secure <onboarding@resend.dev>"

# Auth Server (local dev only — separate Node server on port 3001)
# Production uses /api/auth/* on Vercel directly; leave unset on Vercel.
VITE_AUTH_SERVER_URL=http://localhost:3001

# Python Processing Engine
# Local dev:
VITE_PROCESSING_ENGINE_URL=http://localhost:5000
# Production (Vercel): leave unset — frontend uses same-origin /api via vercel.json proxy.
# Only set this if you want to bypass the proxy and call Render directly:
# VITE_PROCESSING_ENGINE_URL=https://stegagen-api.onrender.com

# Application Settings
VITE_APP_NAME=StegaGen Secure
VITE_APP_VERSION=1.0.0

# Encryption
VITE_ENCRYPTION_KEY=your_encryption_key_here
